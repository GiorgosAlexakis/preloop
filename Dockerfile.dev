FROM python:3.10-slim

WORKDIR /app

# Install system dependencies including PostgreSQL client libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install build dependencies and dev tools
RUN pip install --no-cache-dir build setuptools wheel

# Install the application in development mode
# The actual code will be mounted as a volume
CMD ["sh", "-c", "pip install -e '.[dev]' && python -m spacebridge.db.setup && python -m spacebridge.server"]
