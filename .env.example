# SpaceBridge Environment Configuration

# Database Configuration
DATABASE_URL=postgresql+psycopg://user:password@localhost/spacebridge

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Security
SECRET_KEY=generate_a_secure_random_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Vector Search
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_INTERVAL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=INFO

ANTHROPIC_API_KEY=your_api_key_here
OPENAI_API_KEY=your_api_key_here
LLM_MODEL=claude-3-7-sonnet-latest
GITLAB_API_URL=your_api_url_here
GITLAB_API_KEY=your_api_key_here
JIRA_API_URL=your_api_url_here
JIRA_API_KEY=your_api_key_here
GITHUB_API_URL=your_api_url_here
GITHUB_API_KEY=your_api_key_here
