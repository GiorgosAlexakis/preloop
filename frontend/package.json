{
  "name": "spacelit",
  "version": "1.0.0",
  "description": "SpaceLit frontend rewrite",
  "main": "src/main.ts",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "web-test-runner \"src/**/*.test.{ts,js}\"",
    "test:coverage": "web-test-runner \"src/**/*.test.{ts,js}\" --coverage",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "test:visual:ui": "playwright test tests/visual/ --ui",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "docker:dev": "./docker-run.sh dev",
    "docker:prod": "./docker-run.sh prod",
    "docker:mock": "./docker-run.sh mock",
    "docker:build": "./docker-run.sh build",
    "docker:test": "./docker-run.sh test"
  },
  "dependencies": {
    "@sentry/browser": "^10.5.0",
    "@shoelace-style/shoelace": "^2.20.1",
    "@vaadin/accordion": "^24.8.0",
    "@vaadin/app-layout": "^24.3.0",
    "@vaadin/button": "^24.8.0",
    "@vaadin/card": "^24.8.0",
    "@vaadin/checkbox": "^24.8.0",
    "@vaadin/combo-box": "^24.8.0",
    "@vaadin/date-picker": "^24.8.0",
    "@vaadin/details": "^24.8.0",
    "@vaadin/dialog": "^24.8.0",
    "@vaadin/form-layout": "^24.8.0",
    "@vaadin/grid": "^24.8.0",
    "@vaadin/horizontal-layout": "^24.8.0",
    "@vaadin/icons": "^24.8.0",
    "@vaadin/login": "^24.3.0",
    "@vaadin/password-field": "^24.8.0",
    "@vaadin/progress-bar": "^24.8.0",
    "@vaadin/router": "^2.0.1",
    "@vaadin/scroller": "^24.8.0",
    "@vaadin/select": "^24.8.0",
    "@vaadin/side-nav": "^24.8.0",
    "@vaadin/tabs": "^24.3.0",
    "@vaadin/text-field": "^24.8.0",
    "@vaadin/vertical-layout": "^24.8.0",
    "chart.js": "^4.5.0",
    "deck.gl": "^9.1.12",
    "events": "^3.3.0",
    "js-yaml": "^4.1.1",
    "lit": "^3.1.0",
    "marked": "^16.4.1",
    "mermaid": "^10.9.5",
    "tsne-js": "^1.0.3"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.56.1",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^17.0.4",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-playwright": "^0.11.1",
    "chai": "^5.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "sinon": "^21.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.3.0"
  },
  "lint-staged": {
    "src/**/*.ts": "prettier --write"
  }
}
