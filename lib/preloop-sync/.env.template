# Database configuration (from .env.example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spacesync

# Logging configuration
LOG_LEVEL=INFO
# LOG_FILE=/path/to/logs/spacesync.log

# Service configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=5000
SERVICE_POLL_INTERVAL=300  # Poll interval in seconds for non-webhook trackers
SERVICE_WEBHOOK_ENABLED=true  # Enable webhook services where supported


### Initialization script for account generation

# Tracker configuration
TRACKER_TOKEN=your_tracker_api_token_here
TRACKER_URL=https://github.com/username/repository  # Or GitLab URL

# OpenAI configuration
OPENAI_TOKEN=your_openai_api_token_here
OPENAI_URL=https://api.openai.com  # Default OpenAI API URL
